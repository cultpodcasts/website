# Auth0 Management API — staging SPA URL allowlists
# Copy to .env.staging and fill in. Never commit .env.staging.

# Canonical Auth0 tenant host for Management API (not the custom login domain).
# Example: your-tenant.uk.auth0.com  (Dashboard → Tenant Settings → Domain)
AUTH0_MGMT_DOMAIN=

# Token with scopes: read:clients update:clients
# Dashboard → Applications → APIs → Auth0 Management API → Test, or M2M app.
AUTH0_MGMT_TOKEN=

# Staging Angular SPA client id (Dashboard → Applications → your SPA → Client ID)
# Same value as environment.staging.ts auth0.clientId — do not invent a second id.
AUTH0_CLIENT_ID=
